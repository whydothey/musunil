{
  "name": "musunil",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev:api": "pnpm --filter @musunil/api dev",
    "start:api": "pnpm --filter @musunil/api start",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "check": "pnpm typecheck && pnpm test",
    "check:release": "pnpm check && pnpm check:splus && pnpm check:launch-sample && pnpm check:source-diagnostics && pnpm check:law-diagnostics && pnpm check:news-diagnostics && pnpm check:ops-diagnostics && pnpm check:ops-scheduler && pnpm check:redaction-smoke-safety && pnpm check:mobile-integrity-smoke-safety && pnpm check:render-runtime-secret-safety && pnpm check:render-blueprint-contract && pnpm check:cloudflare-dns-template && pnpm check:cloudflare-headers && pnpm check:render-runtime-config && pnpm check:runtime-smoke && pnpm check:web-manifest && pnpm check:web-smoke && pnpm check:web-flow && pnpm check:report-flow && pnpm check:ux-surface && pnpm check:visual-surface && pnpm check:visual-surface:production-fallback && pnpm check:web-render-build-command && pnpm check:build-info-clean",
    "check:splus": "node scripts/splus-tracker-check.mjs",
    "dev:web": "node scripts/serve-web.mjs",
    "dev:web-next": "MUSUNIL_UI_DATA_MODE=fixture pnpm --filter @musunil/web dev",
    "build:web-next:fixture": "MUSUNIL_UI_DATA_MODE=fixture pnpm --filter @musunil/web build",
    "build:web-next:production": "MUSUNIL_UI_DATA_MODE=production pnpm --filter @musunil/web build",
    "check:web-next:visual": "pnpm build:web-next:fixture && node scripts/ci-web-next-visual.mjs",
    "check:web-next:production": "pnpm build:web-next:production && node scripts/ci-web-next-production.mjs",
    "build:web-config": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/write-web-config.mjs",
    "build:web-static": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/write-web-config.mjs --static && corepack pnpm build:web-headers && MUSUNIL_UI_DATA_MODE=production corepack pnpm --filter @musunil/web build && corepack pnpm build:web-manifest",
    "build:web-static:render": "MUSUNIL_WEB_API_BASE_URL=${MUSUNIL_WEB_API_BASE_URL:-https://api.musunil.com} MUSUNIL_WRITE_BUILD_INFO=1 corepack pnpm build:web-static && MUSUNIL_WEB_API_BASE_URL=${MUSUNIL_WEB_API_BASE_URL:-https://api.musunil.com} MUSUNIL_WRITE_BUILD_INFO=1 corepack pnpm check:web-render-build-output && MUSUNIL_WEB_API_BASE_URL=${MUSUNIL_WEB_API_BASE_URL:-https://api.musunil.com} corepack pnpm check:web-smoke",
    "build:web-headers": "node scripts/write-web-headers.mjs",
    "build:web-manifest": "node scripts/write-web-static-manifest.mjs",
    "check:web-manifest": "MUSUNIL_WEB_API_BASE_URL=https://api.musunil.com corepack pnpm build:web-static && node scripts/write-web-static-manifest.mjs --check",
    "assets:redacted-preview": "node scripts/generate-redacted-preview-assets.mjs",
    "config:encode": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/encode-user-inputs.mjs",
    "db:migrate": "pnpm --filter @musunil/api migrate",
    "launch:check": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/launch-check.mjs",
    "check:launch-sample": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/ci-launch-check.mjs",
    "check:render-runtime-config": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/ci-render-runtime-config.mjs",
    "check:runtime-smoke": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/ci-runtime-smoke.mjs",
    "check:source-diagnostics": "pnpm --filter @musunil/public-source-ingest dev -- --diagnose --require-operational-readiness",
    "check:law-diagnostics": "pnpm --filter @musunil/public-source-ingest dev -- --laws-diagnose --require-law-metadata",
    "check:news-diagnostics": "pnpm --filter @musunil/public-source-ingest dev -- --news-diagnose --require-news-metadata",
    "check:laws-live": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/law-source-live-integration.mjs",
    "check:ops-diagnostics": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/operational-readiness-diagnostics.mjs --template --require-metadata",
    "check:ops-scheduler": "pnpm --filter @musunil/api ops-scheduler:check",
    "check:redaction-smoke-safety": "node scripts/ci-redaction-smoke-safety.mjs",
    "check:mobile-integrity-smoke-safety": "node scripts/ci-mobile-integrity-smoke-safety.mjs",
    "check:render-runtime-secret-safety": "node scripts/ci-render-runtime-secret-safety.mjs",
    "check:render-blueprint-contract": "node scripts/ci-render-blueprint-contract.mjs",
    "check:cloudflare-dns-template": "node scripts/cloudflare-dns-template.mjs -- --check",
    "check:cloudflare-headers": "node scripts/cloudflare-response-headers-template.mjs -- --check",
    "check:web-smoke": "node scripts/ci-web-next-production.mjs",
    "check:web-render-build-output": "node scripts/ci-web-render-build-output.mjs",
    "check:web-render-build-command": "node scripts/ci-web-render-build-command.mjs",
    "check:web-flow": "node scripts/ci-web-next-production.mjs",
    "check:ux-surface": "node scripts/ci-web-next-production.mjs",
    "check:visual-surface": "pnpm check:web-next:visual",
    "check:reels-staging": "node scripts/ci-reels-staging-smoke.mjs",
    "check:report-flow": "node scripts/ci-web-next-production.mjs",
    "check:visual-surface:production-fallback": "pnpm check:web-next:production",
    "check:visual-surface:live": "node scripts/ci-web-next-visual.mjs --base-url https://musunil.com",
    "check:visual-surface:evidence": "pnpm check:web-next:visual",
    "check:visual-surface:live:evidence": "node scripts/ci-web-next-visual.mjs --base-url https://musunil.com --evidence-dir docs/visual-evidence/live-current",
    "check:build-info-clean": "node scripts/ci-build-info-clean.mjs",
    "smoke:api": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/runtime-smoke.mjs",
    "storage:smoke": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/storage-smoke.mjs",
    "redaction:smoke": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/redaction-smoke.mjs",
    "redaction:worker": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/redaction-worker.mjs",
    "mobile:integrity-smoke": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/mobile-integrity-smoke.mjs",
    "identity:smoke": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/identity-smoke.mjs",
    "launch:external-smoke": "node scripts/external-smoke.mjs",
    "launch:ready": "node scripts/launch-ready.mjs",
    "launch:apply": "node scripts/launch-apply.mjs",
    "launch:apply:plan": "node scripts/launch-apply.mjs -- --json",
    "launch:post-deploy-smoke": "node scripts/post-deploy-smoke-runner.mjs",
    "launch:post-deploy-workflow": "node scripts/github-post-deploy-workflow.mjs",
    "launch:final-gate": "node scripts/launch-final-gate.mjs",
    "service:watch": "node scripts/service-watch.mjs",
    "service:watch:visual": "node scripts/service-watch.mjs -- --once --with-visual",
    "check:web-deploy": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/check-web-deploy.mjs",
    "ops:diagnose": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/operational-readiness-diagnostics.mjs",
    "render:api-settings": "node scripts/render-api-settings.mjs",
    "render:web-settings": "node scripts/render-web-settings.mjs",
    "render:apply": "node scripts/render-apply.mjs",
    "render:apply:plan": "node scripts/render-apply.mjs -- --json",
    "render:runtime-secret": "node scripts/render-runtime-secret.mjs",
    "render:provisioning-plan": "node scripts/render-provisioning-plan.mjs",
    "cloudflare:check": "node scripts/cloudflare-dns-check.mjs",
    "cloudflare:check:strict": "node scripts/cloudflare-dns-check.mjs -- --strict",
    "cloudflare:dns": "node scripts/cloudflare-dns-template.mjs",
    "cloudflare:headers": "node scripts/cloudflare-response-headers-template.mjs",
    "cloudflare:apply": "node scripts/cloudflare-apply.mjs",
    "cloudflare:apply:plan": "node scripts/cloudflare-apply.mjs -- --json",
    "launch:cutover-plan": "node scripts/launch-cutover-plan.mjs",
    "launch:cutover-rehearsal": "node scripts/launch-cutover-rehearsal.mjs",
    "launch:operator-brief": "node scripts/launch-operator-brief.mjs",
    "launch:missing-inputs": "node scripts/launch-missing-inputs.mjs",
    "launch:handoff": "node scripts/launch-handoff.mjs",
    "ci:status": "node scripts/github-ci-status.mjs",
    "launch:next-actions": "node scripts/launch-next-actions.mjs",
    "launch:blockers": "node scripts/launch-next-actions.mjs",
    "launch:blockers:strict": "node scripts/launch-next-actions.mjs -- --fail-on-blockers",
    "launch:blockers:refresh-strict": "node scripts/launch-next-actions.mjs -- --refresh --fail-on-blockers",
    "launch:inputs": "node scripts/create-launch-inputs.mjs",
    "check:user-inputs-shape": "node scripts/check-user-inputs-shape.mjs",
    "launch:verify-inputs": "node scripts/check-launch-inputs.mjs",
    "sources:coverage": "pnpm --filter @musunil/public-source-ingest dev -- --coverage",
    "sources:diagnose": "pnpm --filter @musunil/public-source-ingest dev -- --diagnose",
    "sources:assemblies": "pnpm --filter @musunil/public-source-ingest dev",
    "sources:assemblies:post": "pnpm --filter @musunil/public-source-ingest dev -- --post",
    "sources:refresh-preflight": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/public-source-refresh-preflight.mjs",
    "sources:laws-diagnose": "pnpm --filter @musunil/public-source-ingest dev -- --laws-diagnose",
    "sources:laws": "pnpm --filter @musunil/public-source-ingest dev -- --laws",
    "sources:laws:post": "pnpm --filter @musunil/public-source-ingest dev -- --laws --post",
    "sources:news-diagnose": "pnpm --filter @musunil/public-source-ingest dev -- --news-diagnose",
    "sources:news": "pnpm --filter @musunil/public-source-ingest dev -- --news",
    "sources:news:post": "pnpm --filter @musunil/public-source-ingest dev -- --news --post",
    "sources:laws:db-sync": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/law-db-sync.mjs",
    "admin:privacy": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/admin-review.mjs privacy",
    "admin:risk": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/admin-review.mjs risk",
    "admin:queue": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/admin-review.mjs queue",
    "admin:claim": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/admin-review.mjs claim",
    "admin:redaction": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/admin-review.mjs redaction",
    "admin:news": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/admin-review.mjs news",
    "admin:news-candidate": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/admin-review.mjs news-candidate",
    "dispatch:notifications": "pnpm --filter @musunil/notification-dispatch dev",
    "privacy:purge": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/privacy-purge.mjs",
    "ops:scheduler": "pnpm --filter @musunil/api ops-scheduler"
  },
  "devDependencies": {
    "@types/node": "^24.0.14",
    "axe-core": "^4.12.1",
    "playwright-core": "^1.61.1",
    "typescript": "^5.9.2"
  }
}
