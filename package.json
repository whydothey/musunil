{
  "name": "musunil",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev:api": "pnpm --filter @musunil/api dev",
    "start:api": "pnpm --filter @musunil/api start",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "check": "pnpm typecheck && pnpm test",
    "check:release": "pnpm check && pnpm check:splus && pnpm check:launch-sample && pnpm check:render-runtime-config && pnpm check:runtime-smoke && pnpm check:web-smoke",
    "check:splus": "node scripts/splus-tracker-check.mjs",
    "dev:web": "node scripts/serve-web.mjs",
    "build:web-config": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/write-web-config.mjs",
    "config:encode": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/encode-user-inputs.mjs",
    "db:migrate": "pnpm --filter @musunil/api migrate",
    "launch:check": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/launch-check.mjs",
    "check:launch-sample": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/ci-launch-check.mjs",
    "check:render-runtime-config": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/ci-render-runtime-config.mjs",
    "check:runtime-smoke": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/ci-runtime-smoke.mjs",
    "check:web-smoke": "node scripts/ci-web-smoke.mjs",
    "smoke:api": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/runtime-smoke.mjs",
    "storage:smoke": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/storage-smoke.mjs",
    "redaction:smoke": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/redaction-smoke.mjs",
    "mobile:integrity-smoke": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/mobile-integrity-smoke.mjs",
    "launch:external-smoke": "node scripts/external-smoke.mjs",
    "launch:ready": "node scripts/launch-ready.mjs",
    "launch:post-deploy-smoke": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/post-deploy-smoke.mjs",
    "launch:inputs": "node scripts/create-launch-inputs.mjs",
    "launch:verify-inputs": "node scripts/check-launch-inputs.mjs",
    "sources:coverage": "pnpm --filter @musunil/public-source-ingest dev -- --coverage",
    "sources:laws": "pnpm --filter @musunil/public-source-ingest dev -- --laws",
    "admin:privacy": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/admin-review.mjs privacy",
    "admin:risk": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/admin-review.mjs risk",
    "admin:queue": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/admin-review.mjs queue",
    "admin:claim": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/admin-review.mjs claim",
    "admin:redaction": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/admin-review.mjs redaction",
    "dispatch:notifications": "pnpm --filter @musunil/notification-dispatch dev",
    "privacy:purge": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/privacy-purge.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.0.14",
    "typescript": "^5.9.2"
  }
}
