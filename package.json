{
  "name": "musunil",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev:api": "pnpm --filter @musunil/api dev",
    "start:api": "pnpm --filter @musunil/api start",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "check": "pnpm typecheck && pnpm test",
    "check:release": "pnpm check && pnpm check:splus && pnpm check:launch-sample && pnpm check:source-diagnostics && pnpm check:law-diagnostics && pnpm check:ops-diagnostics && pnpm check:cloudflare-dns-template && pnpm check:cloudflare-headers && pnpm check:render-runtime-config && pnpm check:runtime-smoke && pnpm check:web-manifest && pnpm check:web-smoke && pnpm check:web-flow && pnpm check:ux-surface && pnpm check:visual-surface && pnpm check:visual-surface:production-fallback && pnpm check:build-info-clean",
    "check:splus": "node scripts/splus-tracker-check.mjs",
    "dev:web": "node scripts/serve-web.mjs",
    "build:web-config": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/write-web-config.mjs",
    "build:web-static": "pnpm assets:redacted-preview && node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/write-web-config.mjs --static && pnpm build:web-headers && pnpm build:web-manifest",
    "build:web-static:render": "MUSUNIL_WEB_API_BASE_URL=https://api.musunil.com MUSUNIL_WRITE_BUILD_INFO=1 pnpm build:web-static && MUSUNIL_WEB_API_BASE_URL=https://api.musunil.com pnpm check:web-smoke",
    "build:web-headers": "node scripts/write-web-headers.mjs",
    "build:web-manifest": "node scripts/write-web-static-manifest.mjs",
    "check:web-manifest": "MUSUNIL_WEB_API_BASE_URL=https://api.musunil.com pnpm build:web-static && node scripts/write-web-static-manifest.mjs --check",
    "assets:redacted-preview": "node scripts/generate-redacted-preview-assets.mjs",
    "config:encode": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/encode-user-inputs.mjs",
    "db:migrate": "pnpm --filter @musunil/api migrate",
    "launch:check": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/launch-check.mjs",
    "check:launch-sample": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/ci-launch-check.mjs",
    "check:render-runtime-config": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/ci-render-runtime-config.mjs",
    "check:runtime-smoke": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/ci-runtime-smoke.mjs",
    "check:source-diagnostics": "pnpm --filter @musunil/public-source-ingest dev -- --diagnose --require-operational-readiness",
    "check:law-diagnostics": "pnpm --filter @musunil/public-source-ingest dev -- --laws-diagnose --require-law-metadata",
    "check:ops-diagnostics": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/operational-readiness-diagnostics.mjs --template --require-metadata",
    "check:cloudflare-dns-template": "node scripts/cloudflare-dns-template.mjs -- --check",
    "check:cloudflare-headers": "node scripts/cloudflare-response-headers-template.mjs -- --check",
    "check:web-smoke": "node scripts/ci-web-smoke.mjs",
    "check:web-flow": "node scripts/ci-web-flow-smoke.mjs",
    "check:ux-surface": "node scripts/ci-ux-surface-smoke.mjs",
    "check:visual-surface": "node scripts/ci-visual-surface-smoke.mjs",
    "check:visual-surface:production-fallback": "node scripts/ci-visual-surface-smoke.mjs --production-fallback",
    "check:visual-surface:live": "node scripts/ci-visual-surface-smoke.mjs --base-url https://musunil.com",
    "check:build-info-clean": "node scripts/ci-build-info-clean.mjs",
    "smoke:api": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/runtime-smoke.mjs",
    "storage:smoke": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/storage-smoke.mjs",
    "redaction:smoke": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/redaction-smoke.mjs",
    "mobile:integrity-smoke": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/mobile-integrity-smoke.mjs",
    "identity:smoke": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/identity-smoke.mjs",
    "launch:external-smoke": "node scripts/external-smoke.mjs",
    "launch:ready": "node scripts/launch-ready.mjs",
    "launch:post-deploy-smoke": "node scripts/post-deploy-smoke-runner.mjs",
    "launch:final-gate": "node scripts/launch-final-gate.mjs",
    "service:watch": "node scripts/service-watch.mjs",
    "service:watch:visual": "node scripts/service-watch.mjs -- --once --with-visual",
    "check:web-deploy": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/check-web-deploy.mjs",
    "ops:diagnose": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/operational-readiness-diagnostics.mjs",
    "render:api-settings": "node scripts/render-api-settings.mjs",
    "render:web-settings": "node scripts/render-web-settings.mjs",
    "render:apply": "node scripts/render-apply.mjs",
    "render:apply:plan": "node scripts/render-apply.mjs -- --json",
    "cloudflare:check": "node scripts/cloudflare-dns-check.mjs",
    "cloudflare:check:strict": "node scripts/cloudflare-dns-check.mjs -- --strict",
    "cloudflare:dns": "node scripts/cloudflare-dns-template.mjs",
    "cloudflare:headers": "node scripts/cloudflare-response-headers-template.mjs",
    "cloudflare:apply": "node scripts/cloudflare-apply.mjs",
    "cloudflare:apply:plan": "node scripts/cloudflare-apply.mjs -- --json",
    "launch:cutover-plan": "node scripts/launch-cutover-plan.mjs",
    "launch:cutover-rehearsal": "node scripts/launch-cutover-rehearsal.mjs",
    "launch:operator-brief": "node scripts/launch-operator-brief.mjs",
    "launch:next-actions": "node scripts/launch-next-actions.mjs",
    "launch:blockers": "node scripts/launch-next-actions.mjs",
    "launch:blockers:strict": "node scripts/launch-next-actions.mjs -- --fail-on-blockers",
    "launch:blockers:refresh-strict": "node scripts/launch-next-actions.mjs -- --refresh --fail-on-blockers",
    "launch:inputs": "node scripts/create-launch-inputs.mjs",
    "launch:verify-inputs": "node scripts/check-launch-inputs.mjs",
    "sources:coverage": "pnpm --filter @musunil/public-source-ingest dev -- --coverage",
    "sources:diagnose": "pnpm --filter @musunil/public-source-ingest dev -- --diagnose",
    "sources:laws-diagnose": "pnpm --filter @musunil/public-source-ingest dev -- --laws-diagnose",
    "sources:laws": "pnpm --filter @musunil/public-source-ingest dev -- --laws",
    "admin:privacy": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/admin-review.mjs privacy",
    "admin:risk": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/admin-review.mjs risk",
    "admin:queue": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/admin-review.mjs queue",
    "admin:claim": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/admin-review.mjs claim",
    "admin:redaction": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/admin-review.mjs redaction",
    "dispatch:notifications": "pnpm --filter @musunil/notification-dispatch dev",
    "privacy:purge": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/privacy-purge.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.0.14",
    "typescript": "^5.9.2"
  }
}
